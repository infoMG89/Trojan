<Window x:Class="LineProperties.UI.ConnectionListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Přehled spojů (Connections)"
        Width="640" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="300"
        Background="#FFF5F5F5"
        FontFamily="Segoe UI"
        FontSize="12">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Spoje mezi prvky (Connection ID, typ, kód, prvky):" FontWeight="SemiBold"/>
        <DataGrid Grid.Row="2" x:Name="DgConnections"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Background="White"
                  BorderBrush="#FFCCCCCC"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ConnectionId}" Width="80"/>
                <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="50"/>
                <DataGridTextColumn Header="Kód" Binding="{Binding Code}" Width="60"/>
                <DataGridTextColumn Header="Prvek 1" Binding="{Binding Element1}" Width="*"/>
                <DataGridTextColumn Header="Prvek 2" Binding="{Binding Element2}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Zavřít" Width="90" Padding="12,6" Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
