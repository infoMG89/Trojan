<Window x:Class="LineProperties.UI.ElementListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Joists a deck (SMARTJOIST_LIST)"
        Width="520" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="400" MinHeight="300"
        Background="#FFF5F5F5"
        FontFamily="Segoe UI"
        FontSize="12">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Image x:Name="LogoImage" Width="80" Height="36" Stretch="Uniform" Margin="0,0,8,0"/>
            <Image x:Name="LogoImage2" Width="80" Height="36" Stretch="Uniform"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="Joists a deck (MORAVIO_SMART):" FontWeight="SemiBold"/>
        <DataGrid Grid.Row="4" x:Name="DgElements"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Background="White"
                  BorderBrush="#FFCCCCCC"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mark" Binding="{Binding Mark}" Width="60"/>
                <DataGridTextColumn Header="Type" Binding="{Binding MemberType}" Width="70"/>
                <DataGridTextColumn Header="Designation" Binding="{Binding Designation}" Width="100"/>
                <DataGridTextColumn Header="Layer" Binding="{Binding Layer}" Width="*"/>
                <DataGridTextColumn Header="Span" Binding="{Binding Dimensions}" Width="80"/>
                <DataGridTextColumn Header="Handle" Binding="{Binding Handle}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Padding="12,6" Click="BtnClose_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Padding="12,6" Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
