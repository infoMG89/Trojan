<Window x:Class="LineProperties.UI.SmartDeckOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Deck - Plech (obdélník)"
        Width="360" Height="160"
        MinWidth="300" MinHeight="140"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Image x:Name="LogoImage" Width="80" Height="36" Stretch="Uniform" Margin="0,0,8,0"/>
            <Image x:Name="LogoImage2" Width="80" Height="36" Stretch="Uniform"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Typ plechu:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CmbPlateType" IsEditable="True"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Mark:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtMark" Text="P1"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="BtnOk_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
