<Window x:Class="LineProperties.UI.ConnectionCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vyberte kód spoje"
        Width="320" Height="200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="IdText" FontWeight="Bold" FontSize="14"/>
        <TextBlock Grid.Row="2" Text="Kód druhu spoje:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" x:Name="CodeCombo" Height="28" DisplayMemberPath="Display"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Zrušit" Width="80" Height="28" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
